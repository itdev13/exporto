{
  "redirects": [
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "install", "value": "exportKit" },
        { "type": "query", "key": "source", "value": "(?<source>.*)" },
        { "type": "query", "key": "campaign", "value": "(?<campaign>.*)" }
      ],
      "destination": "https://convoapi.vaultsuite.store/oauth/authorize?ref=:source&campaign=:campaign",
      "statusCode": 302
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "install", "value": "exportKit" },
        { "type": "query", "key": "source", "value": "(?<source>.*)" }
      ],
      "destination": "https://convoapi.vaultsuite.store/oauth/authorize?ref=:source",
      "statusCode": 302
    }
  ]
}
